<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><link rel="stylesheet" href="/css/styles.css"><title>Mods</title></head><body>
<%- include('partials/header') %>
<main class="page mods">
<h1>Mods</h1>
<% if (notice) { %><p class="notice"><%= notice %></p><% } %>
<div class="mods-table">
<div class="head"><span>Mod Title</span><span>Link</span><span>Vote</span><span></span></div>
<% mods.forEach((mod) => { %>
<div class="row">
  <span><%= mod.name %></span>
  <a href="<%= mod.link || '#' %>"><%= mod.link || 'No link' %></a>
  <div class="vote-controls">
    <form method="post" action="/mods/vote"><input type="hidden" name="modKey" value="<%= mod.key %>"><input type="hidden" name="delta" value="1"><button class="vote-button up <%= mod.currentVote === 1 ? 'active' : '' %>" aria-pressed="<%= mod.currentVote === 1 ? 'true' : 'false' %>" title="<%= mod.upvoters.length ? `Agrees: ${mod.upvoters.join(', ')}` : 'No agrees yet' %>" aria-label="Upvote <%= mod.name %>">▲</button></form>
    <span><%= mod.score %></span>
    <form method="post" action="/mods/vote"><input type="hidden" name="modKey" value="<%= mod.key %>"><input type="hidden" name="delta" value="-1"><button class="vote-button down <%= mod.currentVote === -1 ? 'active' : '' %>" aria-pressed="<%= mod.currentVote === -1 ? 'true' : 'false' %>" title="<%= mod.downvoters.length ? `Disagrees: ${mod.downvoters.join(', ')}` : 'No disagrees yet' %>" aria-label="Downvote <%= mod.name %>">▼</button></form>
  </div>
  <% if (isAdmin) { %>
    <form method="post" action="/mods/delete" class="delete-mod" onsubmit="return confirm('Are you sure you want to delete <%= mod.name %>?');"><input type="hidden" name="modKey" value="<%= mod.key %>"><button type="submit" aria-label="Delete <%= mod.name %>">X</button></form>
  <% } %>
</div>
<% }) %>
</div>
<p>Mods are ranked by votes.</p>
<details class="suggest-panel">
  <summary>Suggest</summary>
  <form method="post" action="/mods/suggest" class="suggest-box">
    <input name="name" placeholder="Mod Name" required>
    <input name="link" placeholder="Modrinth or CurseForge link" required>
    <button type="submit">Suggest</button>
  </form>
</details>
</main>
<%- include('partials/userbar') %>
</body></html>
