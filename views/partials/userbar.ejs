<div class="userbox">
  <% if (currentUser) { %>
    <span><strong><%= currentUser.name %></strong> |</span>
    <form action="/logout" method="post">
      <button type="submit" class="signout">Sign Out</button>
    </form>
  <% } else { %>
    <a href="/login" class="login-link">Log In</a>
  <% } %>
</div>
